# === 数据库 ===
POSTGRES_USER=ragkb
POSTGRES_PASSWORD=ragkb_secret
POSTGRES_DB=ragkb
DATABASE_URL=postgresql+asyncpg://ragkb:ragkb_secret@postgres:5432/ragkb

# === Qdrant ===
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=

# === Redis ===
REDIS_HOST=redis
REDIS_PORT=6379

# === MinIO ===
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minio_secret
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minio_secret
MINIO_BUCKET=ragkb-docs

# === Ollama ===
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_GENERATION_MODEL=qwen2.5:7b

# === RAG Controller ===
RAG_LOG_LEVEL=info
RAG_SECRET_KEY=change_me_in_production
RAG_CORS_ORIGINS=*
