# ============================================
# Local RAG KB — 环境配置
# 复制此文件为 .env 并修改配置:
#   cp .env.example .env
# ============================================

# === 数据库（PostgreSQL）===
POSTGRES_USER=ragkb
POSTGRES_PASSWORD=ragkb_secret
POSTGRES_DB=ragkb
DATABASE_URL=postgresql+asyncpg://ragkb:ragkb_secret@postgres:5432/ragkb

# === Qdrant（向量数据库）===
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=

# === Redis（缓存）===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# === MinIO（对象存储）===
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minio_secret
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minio_secret
MINIO_BUCKET=ragkb-docs

# === 本地 LLM（Ollama）===
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_GENERATION_MODEL=qwen2.5:7b

# === 云端 LLM（可选 — 不设置则使用 Ollama）===
# 至少设置一个 API Key 即可启用云端 LLM
# 优先级: DeepSeek > OpenAI > Claude > Ollama
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

CLAUDE_API_KEY=
CLAUDE_API_BASE=https://api.anthropic.com
CLAUDE_MODEL=claude-sonnet-4-20250514

# === Embedding & Rerank 模型 ===
# embedding: nomic-embed-text, bge-m3, jina-embeddings-v3, etc.
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768
# rerank: bge-reranker-v2-m3, jina-reranker-v2, etc.
RERANK_MODEL=
RERANK_ENABLED=false

# === 检索参数 ===
CHUNK_SIZE=512
CHUNK_OVERLAP=64
CHUNK_STRATEGY=recursive       # recursive | semantic | code_aware
TOP_K=5
RERANK_TOP_K=5
SEARCH_SCORE_THRESHOLD=0.0
HYBRID_SEARCH_ENABLED=true
HYBRID_DENSE_WEIGHT=0.7
HYBRID_SPARSE_WEIGHT=0.3

# === 生成参数 ===
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048
LLM_CONTEXT_WINDOW=8000

# === RAG Controller ===
RAG_LOG_LEVEL=info
RAG_SECRET_KEY=change_me_in_production
RAG_CORS_ORIGINS=*
RAG_DATA_DIR=./data
